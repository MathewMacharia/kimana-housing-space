rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Listings: Anyone can read, only authenticated landlords can create/update their own
    match /listings/{listingId} {
      allow read: if true;
      allow create, update: if request.auth != null && (
        request.resource.data.landlordId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
    }
    
    // 2. Tenants: Users can only read/write their own profiles
    match /tenants/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 3. Landlords: Users can only read/write their own profiles
    // CRITICAL: This prevents tenants from reading landlord contact info directly!
    // The Cloud Function (server-side) will handle authorized revealing.
    match /landlords/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 4. Global Settings: Anyone can read, only authorized admins (or any auth for now) can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
