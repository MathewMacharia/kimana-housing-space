rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to validate image uploads
    function isValidImage() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)') 
             && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Rules for profile pictures
    match /profile_pictures/{userId} {
      allow read: if true; // Allows anyone to view profile pictures
      allow write: if request.auth != null 
                   && request.auth.uid == userId 
                   && isValidImage(); // Only owner can upload valid images
    }
    
    // Rules for property photos
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && isValidImage();
    }

    match /listings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && isValidImage();
    }
    
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && isValidImage();
    }
  }
}
