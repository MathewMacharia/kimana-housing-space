rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for profile pictures
    match /profile_pictures/{userId} {
      allow read: if true; // Allows anyone to view profile pictures
      allow write: if request.auth != null && request.auth.uid == userId; // Only owner can upload
    }
    
    // Rules for property photos
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for legacy folders
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
